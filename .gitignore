# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
build/
*.iml
.packages
# pubspec.lock is committed: this is an app (not a package). Locking versions keeps
# CI reproducible and, critically, keeps drift/sqlite3 in sync with the committed
# web/ wasm + worker binaries (version mismatch silently breaks Drift on web).

# IDE
.idea/
.vscode/
*.swp

# Supabase local dev temp files
supabase/.branches/
supabase/.temp/

# macOS
.DS_Store
**/.DS_Store

# Android local signing (never commit keystores)
android/key.properties
android/**/*.jks

# Coverage
coverage/
